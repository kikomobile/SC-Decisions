# Path to store downloaded PDFs
DOWNLOAD_PATH=./downloads

# Path to SQLite database file (Notebook 04 owns this entirely)
DB_PATH=./sc_decisions.db

# Delay between HTTP requests in seconds (be polite to the server)
REQUEST_DELAY=1

# --- Notebook 04 settings ---

# Folder containing downloaded/processed PDFs (same as DOWNLOAD_PATH by default)
PDF_FOLDER=./downloads

# Path to processing manifest produced by Notebook 02
MANIFEST_PATH=./downloads/processing_manifest.json

# Folder for per-volume JSON exports
JSON_EXPORT_PATH=./exports/json

# Path for CSV stats export
STATS_EXPORT_PATH=./exports/stats

# If false, skip volumes already parsed in the DB; if true, re-parse all
FORCE_REFRESH=false

# --- Detection pipeline (T7) ---

# DeepSeek API key for LLM fallback (required for T7/T8 LLM features)
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
